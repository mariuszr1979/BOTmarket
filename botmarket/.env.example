# BOTmarket — environment variables
# Copy to .env and fill in values before running docker-compose up

# ── Database ──────────────────────────────────────────────────────────────────
# Strong random password: openssl rand -hex 32
POSTGRES_PASSWORD=changeme

# ── Beta seeding ──────────────────────────────────────────────────────────────
# CU granted to each new agent on registration (0 = disabled, use seed_cu.py manually)
BETA_SEED_CU=0

# ── Server ports ─────────────────────────────────────────────────────────────
PORT_HTTP=8000
PORT_TCP=9000

# ── Logging ───────────────────────────────────────────────────────────────────
# debug | info | warning | error
LOG_LEVEL=info

# ── Faucet ────────────────────────────────────────────────────────────────────
FAUCET_ENABLED=true

# ── Moltbook agent ────────────────────────────────────────────────────────────
# OLLAMA_URL=http://host.docker.internal:11434

# ── GitHub scout agent ────────────────────────────────────────────────────────
# Classic token (ghp_...) with public_repo + write:discussion scopes
GITHUB_TOKEN=
